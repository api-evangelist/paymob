  "info": {
    "_postman_id": "8bf685e1-865f-47ff-a7ae-29810382067b",
    "name": "Paymob Card Tokens API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Card Tokens API exposes tokenisation operations for saved-card flows (CIT / MIT) and recurring billing. A card token is created the first time a cardholder pays with the \"save card\" flag enabled, then reused on subsequent customer-initiated or merchant-initiated transactions.\n\nContact Support:\n Name: Paymob Developers",
      "type": "text/plain"
    }
  }
